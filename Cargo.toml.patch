[workspace]
resolver = "2"
members = [
    "crates/flowx-core",
    "crates/flowx-cli",
    "crates/flowx-desktop/src-tauri",
    "crates/flowx-python",
]
exclude = ["crates/flowx-desktop"]

default-members = [
    "crates/flowx-core",
    "crates/flowx-cli",
    "crates/flowx-desktop/src-tauri",
]

[workspace.package]
version = "0.1.0"
edition = "2021"
license = "MIT"
repository = "https://github.com/flowx/flowx"

[workspace.dependencies]
tokio = { version = "1.35", features = ["full"] }
async-trait = "0.1"
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
thiserror = "1.0"
anyhow = "1.0"

[patch.crates-io]
time = { path = "time/time" }
time-core = { path = "time/time-core" }
time-macros = { path = "time/time-macros" }
